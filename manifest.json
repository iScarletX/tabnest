{
  "manifest_version": 3,
  "name": "TabNest 🪺 · 让标签有处可栖",
  "version": "0.1.4",
  "description": "智能整理浏览器标签，AI 分组、自动归档、一键释放内存。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "TabNest"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "contextMenus",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "打开 TabNest"
    }
  }
}
